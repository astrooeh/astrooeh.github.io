@article{Grossmann2025,
  abbr      = {A&A},
  pubtype   = {refereed},
  presort   = {001},
  title     = {Improving the stellar age determination through joint modeling of binarity and asteroseismology: Grid modeling of the seismic red giant binary KIC 9163796},
  author    = {Grossmann, D.~H. and Beck, P.~G. and Mathur, S. and Johnston, C. and Godoy-Rivera, D. and Zinn, J.~C. and Cassisi, S. and Liagre, B. and Masseron, T. and Garc{\'\i}a, R.~A. and Hanslmeier, A. and Muntean, N. and Schimak, L.~S. and Steinwender, L. and Stello, D.},
  journal   = {Astronomy \& Astrophysics},
  volume    = {696},
  pages     = {A42},
  year      = {2025},
  month     = apr,
  doi       = {10.1051/0004-6361/202452626},
  arxiv     = {2501.09018},
  abstract  = {Ages of single giants derived from isochrone fitting typically carry uncertainties of 30 to 50 percent. By combining the constraints from binarity, spectroscopy and asteroseismology in a multidimensional grid of stellar models, we determine an age of 2.44 Gyr for the red giant and subgiant binary KIC 9163796, corresponding to a relative age error of 9 percent. Both components share an initial helium abundance well above the primordial value, and the model masses agree with those from the asteroseismic scaling relations.},
  selected  = {true},
  bibtex_show = {true}
}

