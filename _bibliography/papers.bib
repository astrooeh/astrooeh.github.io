@article{Grossmann2026,
  abbr      = {A&A},
  pubtype   = {underreview},
  presort   = {001},
  usera     = {underreview},
  title     = {Ensemble Individual Mode Frequency Modeling of Kepler Giants},
  author    = {Grossmann, D.~H. and Mathur, S. and Beck, P.~G. and Godoy-Rivera, D. and Liagre, B. and Garc{\'\i}a, R.~A. and Schimak, L.~S. and Palakkatharappil, D. and Pinsonneault, M. and P{\'e}rez Hern{\'a}ndez, F.},
  journal   = {Astronomy \& Astrophysics},
  year      = {2026},
  month     = jun,
  abstract  = {Global seismic modeling of red giants leaves random age uncertainties of roughly 20 to 50 percent, and the systematics are rarely quantified. We extend seismic modeling to individual mode frequencies for red giant branch stars, validate the method against literature targets, and apply it to around 100 Kepler red giants of approximately solar mass and metallicity. We obtain average random uncertainties of 3.4 percent in mass, 1.3 percent in radius and 13.2 percent in age, and we find that ages from individual mode frequency modeling are on average 14 percent larger than those from global seismic modeling. Modeling individual mode frequencies improves age precision by a factor of two, providing stronger constraints for galactic archaeology.},
  selected  = {true},
  additional_info = {under review},
  bibtex_show = {true}
}

